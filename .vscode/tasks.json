    {
      "label": "cooper: TUI Test",
      "type": "shell",
      "command": "go build -o ${workspaceFolder}/cooper/cooper ${workspaceFolder}/cooper && ${workspaceFolder}/cooper/cooper tui-test",
      "options": {
        "cwd": "${workspaceFolder}/cooper"
      },
      "presentation": {
        "clear": true,
        "echo": true,
        "focus": true,
        "panel": "new",
        "group": "cooper-tui",
        "close": true,
        "reveal": "always",
        "showReuseMessage": false
      },
      "runOptions": {
        "instanceLimit": 1,
        "reevaluateOnRerun": true
      },
      "problemMatcher": [],
      "isBackground": true
    },
