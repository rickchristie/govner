{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "pgflock: Build",
      "type": "shell",
      "command": "go build -o ${workspaceFolder}/pgflock/pgflock ${workspaceFolder}/pgflock && notify-send 'pgflock' 'Build complete' || { notify-send 'pgflock' 'Build failed'; read -p 'Press Enter to close...'; exit 1; }",
      "options": {
        "cwd": "${workspaceFolder}/pgflock"
      },
      "presentation": {
        "clear": true,
        "echo": true,
        "focus": false,
        "panel": "dedicated",
        "reveal": "silent",
        "close": true,
        "showReuseMessage": false
      },
      "problemMatcher": "$go",
      "isBackground": false
    },
    {
      "label": "gowt: Test Current Package",
      "type": "shell",
      "command": "go clean -testcache && gowt .",
      "options": {
        "cwd": "${fileDirname}"
      },
      "presentation": {
        "clear": true,
        "close": true,
        "echo": true,
        "focus": true,
        "panel": "dedicated",
        "group": "test",
        "reveal": "always",
        "showReuseMessage": false
      },
      "problemMatcher": "$go",
      "isBackground": false
    },
    {
      "label": "gowt: Test All pgflock",
      "type": "shell",
      "command": "go clean -testcache && gowt ./...",
      "options": {
        "cwd": "${workspaceFolder}/pgflock"
      },
      "presentation": {
        "clear": true,
        "close": true,
        "echo": true,
        "focus": true,
        "panel": "dedicated",
        "group": "test",
        "reveal": "always",
