# Cooper CLI: {{.ToolDisplayName}} - Generated by cooper configure
# DO NOT EDIT - This file is regenerated by cooper.
FROM {{.BaseImage}}

{{- if .ToolDirs}}

# Tool directories
USER root
RUN mkdir -p{{range .ToolDirs}} {{.}}{{end}} \
    && chown -R user:user /home/user
{{- end}}

USER user

# Clear inherited proxy env for build-time downloads.
# The proxy (cooper-proxy) only exists at container runtime, not during image build.
ENV HTTP_PROXY=""
ENV HTTPS_PROXY=""

# Install {{.ToolDisplayName}}
{{.InstallCommands}}

# Restore proxy env for runtime (traffic goes through cooper-proxy inside the barrel)
ENV HTTP_PROXY=http://cooper-proxy:{{.ProxyPort}}
ENV HTTPS_PROXY=http://cooper-proxy:{{.ProxyPort}}
ENV NO_PROXY=localhost,127.0.0.1

# Tool identification for entrypoint
ENV COOPER_CLI_TOOL={{.ToolName}}
ENV COOPER_CLI_AUTO_APPROVE="{{.AutoApproveFlag}}"
ENV COOPER_CLIPBOARD_MODE={{.ClipboardMode}}
