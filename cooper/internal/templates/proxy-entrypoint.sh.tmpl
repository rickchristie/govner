#!/bin/bash
# Cooper Proxy Container Entrypoint - Generated by cooper configure
# DO NOT EDIT - This file is regenerated by cooper.
#
# Starts Squid, socat relays for port forwarding and bridge, and logrotate cron.

SOCAT_RULES="/etc/cooper/socat-rules.json"

# ============================================================================
# LOGROTATE CRON
# ============================================================================
# Run logrotate every 15 minutes in the background.
(
    while true; do
        sleep 900
        /usr/sbin/logrotate /etc/logrotate.d/squid 2>/dev/null || true
    done
) &

# ============================================================================
# SOCAT PORT FORWARDING RELAYS (live-reloadable via SIGHUP)
# ============================================================================
# Relay traffic from barrel containers (on internal network) to the host
# via host.docker.internal.
# Rules are read from /etc/cooper/socat-rules.json (volume-mounted from host).

# Parent tracks supervisor PIDs. Each supervisor manages one socat process
# with auto-restart. On reload, parent TERMs supervisors; each supervisor
# traps TERM, kills its socat child, and exits cleanly. No variable sharing
# between parent and subshells, no broad pkill, no stale listeners.
SOCAT_SUPERVISORS=()

run_socat() {
    local listen_port=$1
    local name=$2
    local dest_host=$3
    local dest_port=$4

    (
        child_pid=""

        stop_supervisor() {
            if [ -n "$child_pid" ]; then
                kill "$child_pid" 2>/dev/null || true
                wait "$child_pid" 2>/dev/null || true
            fi
            exit 0
        }

        trap stop_supervisor TERM INT

        while true; do
            echo "[socat:${listen_port}] Starting ${name} relay..."
            socat TCP-LISTEN:${listen_port},bind=0.0.0.0,fork,reuseaddr \
                TCP:${dest_host}:${dest_port} 2>&1 &
            child_pid=$!

            wait "$child_pid"
            exit_code=$?
            child_pid=""

            echo "[socat:${listen_port}] WARNING: ${name} relay exited (${exit_code}), restarting in 1s..." >&2
            sleep 1
        done
    ) &

    SOCAT_SUPERVISORS+=($!)
}

start_socat_from_config() {
    if [ ! -f "$SOCAT_RULES" ]; then
        echo "[socat] WARNING: $SOCAT_RULES not found, using template defaults"
        # Fallback: bridge port from template
        run_socat {{.BridgePort}} "bridge" host.docker.internal {{.BridgePort}}
        return
    fi

    # Read bridge port from config
    local bridge_port
    bridge_port=$(jq -r '.bridge_port // empty' "$SOCAT_RULES" 2>/dev/null)
    if [ -z "$bridge_port" ]; then
        bridge_port={{.BridgePort}}
    fi

    # Start bridge port relay
    run_socat "$bridge_port" "bridge" host.docker.internal "$bridge_port"

    # Read and start port forwarding rules
    local rule_count
    rule_count=$(jq '.rules | length' "$SOCAT_RULES" 2>/dev/null || echo 0)

    for i in $(seq 0 $((rule_count - 1))); do
        local container_port host_port desc is_range range_end
        container_port=$(jq -r ".rules[$i].container_port" "$SOCAT_RULES")
        host_port=$(jq -r ".rules[$i].host_port" "$SOCAT_RULES")
        desc=$(jq -r ".rules[$i].description // \"port-$container_port\"" "$SOCAT_RULES")
        is_range=$(jq -r ".rules[$i].is_range // false" "$SOCAT_RULES")
        range_end=$(jq -r ".rules[$i].range_end // 0" "$SOCAT_RULES")

        if [ "$is_range" = "true" ] && [ "$range_end" -gt "$container_port" ]; then
            for port in $(seq "$container_port" "$range_end"); do
                local hp=$((port - container_port + host_port))
                run_socat "$port" "${desc}-${port}" host.docker.internal "$hp"
            done
        else
            run_socat "$container_port" "$desc" host.docker.internal "$host_port"
        fi
    done

    sleep 0.3
    echo "Socat relays active (from $SOCAT_RULES)"
}

reload_socat() {
    echo "[socat] Reloading socat relays..."
    local old=("${SOCAT_SUPERVISORS[@]}")
    SOCAT_SUPERVISORS=()

    # Send TERM to all old supervisors (each kills its socat child via trap).
    for pid in "${old[@]}"; do
        kill "$pid" 2>/dev/null || true
    done
    # Wait for all old supervisors to finish (ensures ports are released).
    for pid in "${old[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # Start fresh supervisors from config.
    start_socat_from_config
    echo "[socat] Reload complete."
}

# Handle SIGHUP for live reload
trap 'reload_socat' HUP

echo "Starting socat relays..."
start_socat_from_config

# ============================================================================
# SQUID (foreground)
# ============================================================================
echo "Starting Squid proxy..."

# Start squid in background so the shell stays alive for signal handling.
squid -N &
SQUID_PID=$!

# Wait for squid; if it exits, we exit too.
# The shell stays alive to handle SIGHUP via trap.
# When a signal (e.g. SIGHUP) interrupts wait, it returns 128+signal.
# We must re-wait so the shell continues handling signals.
while wait $SQUID_PID; exit_code=$?; do
    # If squid actually exited (not a signal interruption), break.
    if ! kill -0 $SQUID_PID 2>/dev/null; then
        exit $exit_code
    fi
    # Otherwise, a signal interrupted wait — loop and re-wait.
done
