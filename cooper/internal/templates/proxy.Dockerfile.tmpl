# Cooper Proxy Container - Generated by cooper configure
# DO NOT EDIT - This file is regenerated by cooper.
#
# Features:
# - Squid HTTP/HTTPS proxy with SSL bump (TLS interception)
# - Domain whitelisting with external ACL for pending approval
# - socat relays for host service access
# - Log rotation to prevent disk fill

FROM golang:1.24-alpine AS acl-builder

# Build the ACL helper binary from source inside Docker.
# This makes `cooper build` self-contained — no host Go required.
# The source mirrors the exact tested code from the cooper repo.
COPY acl-helper/ /src/
WORKDIR /src
RUN CGO_ENABLED=0 go build -o /cooper-acl-helper ./cmd/acl-helper/

FROM alpine:3.21 AS builder

# Build Squid from source with SSL bump support
# Alpine's squid package may not include --enable-ssl-crtd, so we build from source.
RUN apk add --no-cache \
    build-base \
    openssl-dev \
    perl \
    linux-headers \
    curl

ARG SQUID_VERSION=6.12
RUN curl -Lo /tmp/squid-${SQUID_VERSION}.tar.xz \
        "http://www.squid-cache.org/Versions/v6/squid-${SQUID_VERSION}.tar.xz" && \
    mkdir -p /tmp/squid-build && \
    cd /tmp/squid-build && \
    tar -xf /tmp/squid-${SQUID_VERSION}.tar.xz && \
    cd squid-${SQUID_VERSION} && \
    CXXFLAGS="-Wno-error" CFLAGS="-Wno-error" \
    ./configure \
        --prefix=/usr \
        --sysconfdir=/etc/squid \
        --libexecdir=/usr/lib/squid \
        --localstatedir=/var \
        --datadir=/usr/share/squid \
        --with-openssl \
        --enable-ssl-crtd \
        --enable-icap-client \
        --enable-external-acl-helpers=file_userip \
        --disable-arch-native \
        --with-default-user=squid && \
    make -j$(nproc) && \
    make DESTDIR=/squid-install install && \
    rm -rf /tmp/squid-build /tmp/squid-${SQUID_VERSION}.tar.xz

FROM alpine:3.21

# Install runtime dependencies
RUN apk add --no-cache \
    openssl \
    libstdc++ \
    logrotate \
    bash \
    socat \
    jq \
    ca-certificates

# Copy Squid from builder (copy specific dirs to avoid clobbering Alpine symlinks like /var/run)
COPY --from=builder /squid-install/usr /usr
COPY --from=builder /squid-install/etc/squid /etc/squid

# Create squid user and directories
RUN addgroup -S squid && adduser -S -G squid squid && \
    mkdir -p /var/log/squid /var/spool/squid /var/run/squid && \
    chown -R squid:squid /var/log/squid /var/spool/squid /var/run/squid /etc/squid

# Initialize SSL certificate database for dynamic cert generation.
# security_file_certgen creates the ssl_db directory itself — don't pre-create it.
RUN mkdir -p /var/lib/squid && \
    /usr/lib/squid/security_file_certgen -c -s /var/lib/squid/ssl_db -M 4MB && \
    chown -R squid:squid /var/lib/squid

# Copy default squid.conf (will be overridden by volume mount at runtime)
COPY squid.conf /etc/squid/squid.conf

# Copy CA certificate for SSL bump
COPY cooper-ca.pem /etc/squid/cooper-ca.pem
COPY cooper-ca-key.pem /etc/squid/cooper-ca-key.pem
RUN chown squid:squid /etc/squid/cooper-ca.pem /etc/squid/cooper-ca-key.pem && \
    chmod 400 /etc/squid/cooper-ca-key.pem

# Copy ACL helper binary from Go build stage
COPY --from=acl-builder /cooper-acl-helper /usr/lib/squid/cooper-acl-helper
RUN chmod +x /usr/lib/squid/cooper-acl-helper

# Logrotate config - rotate at 10MB, keep 10 rotations
RUN printf '/var/log/squid/*.log {\n\
    size 10M\n\
    rotate 10\n\
    missingok\n\
    notifempty\n\
    compress\n\
    delaycompress\n\
    postrotate\n\
        squid -k rotate 2>/dev/null || true\n\
    endscript\n\
}\n' > /etc/logrotate.d/squid

# Create entrypoint that starts Squid + socat relays
COPY proxy-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

EXPOSE {{.ProxyPort}}

ENTRYPOINT ["/entrypoint.sh"]
