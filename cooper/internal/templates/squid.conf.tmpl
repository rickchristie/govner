# Cooper Squid Proxy Configuration - Generated by cooper configure
# DO NOT EDIT - This file is regenerated by cooper.
#
# SSL bump proxy with domain whitelisting and external ACL for pending approval.

# Port with SSL bump support
http_port {{.ProxyPort}} ssl-bump \
    cert=/etc/squid/cooper-ca.pem \
    key=/etc/squid/cooper-ca-key.pem \
    generate-host-certificates=on \
    dynamic_cert_mem_cache_size=4MB

# Dynamic certificate generation
sslcrtd_program /usr/lib/squid/security_file_certgen -s /var/lib/squid/ssl_db -M 4MB
sslcrtd_children 5

# SSL bump: peek at SNI then bump all connections
acl step1 at_step SslBump1
ssl_bump peek step1
ssl_bump bump all

# Note: dns_v4_first was removed in Squid 6 (no longer needed).

# Timeouts for streaming/long-lived connections (AI tool API calls)
read_timeout 120 minutes
client_lifetime 1 day
connect_timeout 30 seconds
request_timeout 5 minutes

# Don't buffer streaming responses
quick_abort_min 0 KB
quick_abort_max 0 KB

# Define allowed ports
acl SSL_ports port 443
acl Safe_ports port 443

# Deny non-safe ports
http_access deny !Safe_ports

# ============================================================================
# WHITELISTED DOMAINS
# ============================================================================
{{range .WhitelistedDomains}}
acl allowed_domains dstdomain {{.Domain}}
{{- end}}

# ============================================================================
# EXTERNAL ACL - For non-whitelisted domain approval
# ============================================================================
external_acl_type cooper_acl ttl=0 negative_ttl=0 children-max=20 children-startup=5 %DST %SRC \
    /usr/lib/squid/cooper-acl-helper --socket /var/run/cooper/acl.sock

acl pending_review external cooper_acl

# ============================================================================
# ACCESS RULES
# ============================================================================

# HTTPS: Allow CONNECT to whitelisted domains
http_access allow CONNECT SSL_ports allowed_domains

# HTTPS: Allow CONNECT for pending review (external ACL approved)
http_access allow CONNECT SSL_ports pending_review

# Deny all other CONNECT
http_access deny CONNECT all

# HTTP: Allow whitelisted domains
http_access allow allowed_domains

# HTTP: Allow pending review
http_access allow pending_review

# Deny everything else
http_access deny all

# ============================================================================
# CUSTOM ERROR PAGES
# ============================================================================
# Custom error page that guides AI agents to exhaust local options first,
# then ask the user to approve access via the Cooper monitor.
error_directory /etc/squid/errors

# ============================================================================
# CACHING AND LOGGING
# ============================================================================

# PID file in cooper-owned directory (container runs as non-root cooper user)
pid_filename /var/run/squid/squid.pid

# Disable caching
cache deny all

# Access logging with format suitable for monitor parsing
logformat cooper %ts.%03tu %6tr %>a %Ss/%03>Hs %<st %rm %ru %ssl::>sni %Sh/%<a %mt
access_log /var/log/squid/access.log cooper
cache_log /var/log/squid/cache.log

# Log rotation - rotate when access.log reaches 10MB, keep 2 rotations
logfile_rotate 2
