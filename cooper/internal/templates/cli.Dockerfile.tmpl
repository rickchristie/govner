# Cooper CLI Container (Barrel) - Generated by cooper configure
# DO NOT EDIT - This file is regenerated by cooper. User customizations go in Dockerfile.user.

# Stage 1: Get Node.js from official image
FROM node:lts-bookworm AS node
{{- if .HasGo}}

# Stage 2: Build final image with Go
FROM golang:{{.GoVersion}}-bookworm
{{- else}}

# Stage 2: Build final image from Debian
FROM debian:bookworm-slim
{{- end}}

# Copy Node.js from official image (required for npm-based AI tools)
COPY --from=node /usr/local/bin/node /usr/local/bin/
COPY --from=node /usr/local/lib/node_modules /usr/local/lib/node_modules
RUN ln -s /usr/local/lib/node_modules/npm/bin/npm-cli.js /usr/local/bin/npm && \
    ln -s /usr/local/lib/node_modules/npm/bin/npx-cli.js /usr/local/bin/npx

# ============================================================================
# Base tools installation
# ============================================================================
RUN apt-get update && apt-get install -y --no-install-recommends \
    socat \
    git \
    curl \
    ca-certificates \
    xz-utils \
    ripgrep \
    jq \
{{- if .HasOpenCode}}
    inotify-tools \
    xclip \
    xvfb \
{{- end}}
{{- if .HasCodex}}
    build-essential \
    meson \
    ninja-build \
    pkg-config \
    libcap-dev \
{{- end}}
    && rm -rf /var/lib/apt/lists/*

# ============================================================================
# CACHE_BUST_LANG - Change this value to force rebuild of language layers
# ============================================================================
ARG CACHE_BUST_LANG=1
{{if .HasPython}}
# ============================================================================
# Python installation
# ============================================================================
# Python: install distro-default version. Exact version pinning is not supported
# via apt (distro ships a fixed version). Use pyenv in Dockerfile.user for exact versions.
RUN apt-get update && apt-get install -y --no-install-recommends \
    python3 \
    python3-pip \
    python3-venv \
    && rm -rf /var/lib/apt/lists/* \
    && ln -sf /usr/bin/python3 /usr/bin/python
{{end -}}
{{- if .HasRust}}
# ============================================================================
# Rust installation
# ============================================================================
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --default-toolchain {{.RustVersion}} && \
    . /root/.cargo/env && rustup default {{.RustVersion}}
ENV PATH="/root/.cargo/bin:${PATH}"
{{end -}}
{{- if .HasCodex}}
# ============================================================================
# Bubblewrap build from source (required by OpenAI Codex CLI --argv0 support)
# Debian bookworm ships an older version without this flag
# ============================================================================
RUN BWRAP_VERSION=0.11.0 && \
    BWRAP_TARBALL="bubblewrap-${BWRAP_VERSION}.tar.xz" && \
    curl -Lo "/tmp/${BWRAP_TARBALL}" \
        "https://github.com/containers/bubblewrap/releases/download/v${BWRAP_VERSION}/${BWRAP_TARBALL}" && \
    echo "988fd6b232dafa04b8b8198723efeaccdb3c6aa9c1c7936219d5791a8b7a8646  /tmp/${BWRAP_TARBALL}" | sha256sum -c && \
    mkdir -p /tmp/bwrap-build && cd /tmp/bwrap-build && \
    tar -xf "/tmp/${BWRAP_TARBALL}" && \
    cd "bubblewrap-${BWRAP_VERSION}" && \
    meson setup _builddir --prefix=/usr/local && \
    meson compile -C _builddir && \
    meson install -C _builddir && \
    ln -sf /usr/local/bin/bwrap /usr/bin/bwrap && \
    rm -rf /tmp/bwrap-build "/tmp/${BWRAP_TARBALL}"
{{end}}
# ============================================================================
# User setup - matching host UID/GID for file permissions
# ============================================================================
ARG USER_UID=1000
ARG USER_GID=1000
RUN groupadd --gid ${USER_GID} user 2>/dev/null || true && \
    useradd --uid ${USER_UID} --gid ${USER_GID} -m user 2>/dev/null || true
{{- if .HasGo}} && \
    mkdir -p /go && chown -R user:user /go
{{- end}}

# Setup directories for user
RUN mkdir -p /home/user/.npm-global /home/user/.config /home/user/.local/bin \
{{- if .HasClaudeCode}}
    /home/user/.claude \
{{- end}}
{{- if .HasCopilot}}
    /home/user/.copilot \
{{- end}}
{{- if .HasCodex}}
    /home/user/.codex \
{{- end}}
{{- if .HasOpenCode}}
    /home/user/.config/opencode \
{{- end}}
    && chown -R user:user /home/user

# Copy entrypoint
COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

USER user

# Configure npm to use user-writable directory for global packages
ENV NPM_CONFIG_PREFIX=/home/user/.npm-global
ENV PATH=/home/user/.local/bin:/home/user/.npm-global/bin:$PATH

# ============================================================================
# CACHE_BUST_AI - Change this value to force rebuild of AI tool layers
# ============================================================================
ARG CACHE_BUST_AI=1
{{if .HasClaudeCode}}
# ============================================================================
# Claude Code installation
# ============================================================================
{{- if .ClaudeVersion}}
RUN npm install -g @anthropic-ai/claude-code@{{.ClaudeVersion}}
{{- else}}
RUN curl -fsSL https://claude.ai/install.sh | bash && \
    /home/user/.local/bin/claude install
{{- end}}
{{end -}}
{{- if .HasCopilot}}
# ============================================================================
# GitHub Copilot CLI installation
# ============================================================================
RUN npm install -g @github/copilot{{if .CopilotVersion}}@{{.CopilotVersion}}{{end}}
{{end -}}
{{- if .HasCodex}}
# ============================================================================
# OpenAI Codex CLI installation
# ============================================================================
RUN npm install -g @openai/codex{{if .CodexVersion}}@{{.CodexVersion}}{{end}}
{{end -}}
{{- if .HasOpenCode}}
# ============================================================================
# OpenCode CLI installation
# ============================================================================
RUN curl -fsSL https://opencode.ai/install | bash
RUN mkdir -p /home/user/.config/opencode
{{end}}
# ============================================================================
# CA certificate injection for SSL bump proxy
# ============================================================================
USER root
COPY cooper-ca.pem /usr/local/share/ca-certificates/cooper-ca.crt
RUN update-ca-certificates
USER user

ENV NODE_EXTRA_CA_CERTS=/usr/local/share/ca-certificates/cooper-ca.crt

# ============================================================================
# Proxy environment variables
# ============================================================================
ENV HTTP_PROXY=http://cooper-proxy:{{.ProxyPort}}
ENV HTTPS_PROXY=http://cooper-proxy:{{.ProxyPort}}
ENV NO_PROXY=localhost,127.0.0.1

ENTRYPOINT ["/entrypoint.sh"]
CMD ["bash"]
