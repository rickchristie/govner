if ! grep -q "Cooper: Welcome v3" /home/user/.bashrc 2>/dev/null; then
    cat >> /home/user/.bashrc << 'BANNER'

# Cooper: Welcome v3
if [[ $- == *i* ]]; then
    echo ""
    echo -e "  \033[38;5;130m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""
    echo -e "    \033[1;38;5;214m🥃  c o o p e r\033[0m"
    echo -e "    \033[38;5;223mBarrel-proof containers for undiluted AI\033[0m"
    echo ""
    echo -e "    \033[38;5;108m◆\033[0m Network-isolated    \033[38;5;108m◆\033[0m SSL-inspected"
    echo -e "    \033[38;5;108m◆\033[0m Caps dropped        \033[38;5;108m◆\033[0m Proxy filtered"
    echo ""
    echo -e "  \033[38;5;130m━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\033[0m"
    echo ""
