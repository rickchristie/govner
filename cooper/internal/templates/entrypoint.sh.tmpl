#!/bin/bash
# Cooper CLI Container Entrypoint - Generated by cooper configure
# DO NOT EDIT - This file is regenerated by cooper.
#
# Starts socat port forwarding, configures auto-approve aliases, then executes the command.

# ============================================================================
# Runtime CA certificate update
# ============================================================================
# If a CA cert is volume-mounted at /etc/cooper/cooper-ca.pem (which happens
# when the proxy's CA was regenerated after the barrel image was built), update
# the system trust store so curl/wget/etc. trust the proxy's SSL bump certs.
if [ -f /etc/cooper/cooper-ca.pem ]; then
    cp /etc/cooper/cooper-ca.pem /usr/local/share/ca-certificates/cooper-ca.crt 2>/dev/null || true
    cat /etc/cooper/cooper-ca.pem >> /etc/ssl/certs/ca-certificates.crt 2>/dev/null || true
    export NODE_EXTRA_CA_CERTS=/etc/cooper/cooper-ca.pem
fi

SOCAT_RULES="/etc/cooper/socat-rules.json"

# ============================================================================
# PATH setup — written to the TOP of .bashrc (before Debian's interactive guard)
# so it's available to both interactive shells and autostart commands.
# Also written to .profile for non-bash login shells.
# ============================================================================
COOPER_PATH_LINE='export PATH="/home/user/.local/bin:/home/user/.npm-global/bin:/home/user/.opencode/bin{{- if .HasGo}}:/usr/local/go/bin:/go/bin{{- end}}:$PATH"'

if ! grep -q "Cooper: PATH" /home/user/.bashrc 2>/dev/null; then
    # Prepend to .bashrc (before the interactive guard) so PATH is set
    # even when .bashrc is sourced from .profile in non-interactive context.
    { echo "# Cooper: PATH"; echo "$COOPER_PATH_LINE"; echo ""; cat /home/user/.bashrc 2>/dev/null; } > /home/user/.bashrc.tmp
    mv /home/user/.bashrc.tmp /home/user/.bashrc
fi

if ! grep -q "Cooper: PATH" /home/user/.profile 2>/dev/null; then
    cat >> /home/user/.profile << PATHSETUP

# Cooper: PATH
$COOPER_PATH_LINE
PATHSETUP
fi

# ============================================================================
# Auto-approve alias (set per tool image via ENV)
# ============================================================================
# The alias is appended inside .bashrc's interactive section, so it only works
# in interactive shells (cooper cli <tool> → bash -l). Non-interactive one-shot
# commands (cooper cli <tool> -c "go test") don't load aliases, but that's fine
# because one-shot commands run user code, not the AI tool itself.
if [ -n "$COOPER_CLI_TOOL" ] && [ -n "$COOPER_CLI_AUTO_APPROVE" ]; then
    if ! grep -q "Cooper: Auto-approve alias" /home/user/.bashrc 2>/dev/null; then
        cat >> /home/user/.bashrc << ALIAS

# Cooper: Auto-approve alias
alias $COOPER_CLI_TOOL='$COOPER_CLI_TOOL $COOPER_CLI_AUTO_APPROVE'
ALIAS
    fi
fi

# ============================================================================
# OpenCode setup (conditional on tool type)
# ============================================================================
if [ "$COOPER_CLI_TOOL" = "opencode" ]; then
    if ! grep -q "Cooper: DISPLAY" /home/user/.bashrc 2>/dev/null; then
        echo '# Cooper: DISPLAY for headless clipboard support' >> /home/user/.bashrc
        echo 'export DISPLAY=:99.0' >> /home/user/.bashrc
    fi

    # OpenCode config: create defaults only if not already present (dir is host-mounted)
    mkdir -p /home/user/.config/opencode/plugins /home/user/.config/opencode/commands
    if [ ! -f /home/user/.config/opencode/opencode.json ]; then
        echo '{"$schema": "https://opencode.ai/config.json", "autoupdate": false}' > /home/user/.config/opencode/opencode.json
    fi

    # Start Xvfb virtual display for headless clipboard/display support
    Xvfb :99 -screen 0 1024x768x24 > /dev/null 2>&1 &
    export DISPLAY=:99.0
fi

# ============================================================================
# SOCAT PORT FORWARDING (live-reloadable via SIGHUP)
# ============================================================================
# Two-hop relay: CLI socat -> cooper-proxy:{port} -> proxy socat -> host
# Destination is cooper-proxy via Docker DNS on the internal network.
# Rules are read from /etc/cooper/socat-rules.json (volume-mounted from host).

# Parent tracks supervisor PIDs. Each supervisor manages one socat process
# with auto-restart. On reload, parent TERMs supervisors; each supervisor
# traps TERM, kills its socat child, and exits cleanly.
SOCAT_SUPERVISORS=()

run_socat() {
    local port=$1
    local name=$2
    local dest_host=${3:-cooper-proxy}
    local dest_port=${4:-$port}

    (
        child_pid=""

        stop_supervisor() {
            if [ -n "$child_pid" ]; then
                kill "$child_pid" 2>/dev/null || true
                wait "$child_pid" 2>/dev/null || true
            fi
            exit 0
        }

        trap stop_supervisor TERM INT

        while true; do
            echo "[socat:${port}] Starting ${name} forwarder..."
            socat TCP-LISTEN:${port},bind=127.0.0.1,fork,reuseaddr,backlog=5000 \
                TCP:${dest_host}:${dest_port} 2>&1 &
            child_pid=$!

            wait "$child_pid"
            exit_code=$?
            child_pid=""

            echo "[socat:${port}] WARNING: ${name} forwarder exited (${exit_code}), restarting in 1s..." >&2
            sleep 1
        done
    ) &

    SOCAT_SUPERVISORS+=($!)
}

start_socat_from_config() {
    if [ ! -f "$SOCAT_RULES" ]; then
        echo "[socat] WARNING: $SOCAT_RULES not found, using template defaults"
        # Fallback: bridge port from template
        run_socat {{.BridgePort}} "bridge"
        return
    fi

    # Read bridge port from config
    local bridge_port
    bridge_port=$(jq -r '.bridge_port // empty' "$SOCAT_RULES" 2>/dev/null)
    if [ -z "$bridge_port" ]; then
        bridge_port={{.BridgePort}}
    fi

    # Start bridge port forwarder
    run_socat "$bridge_port" "bridge"

    # Read and start port forwarding rules
    local rule_count
    rule_count=$(jq '.rules | length' "$SOCAT_RULES" 2>/dev/null || echo 0)

    for i in $(seq 0 $((rule_count - 1))); do
        local container_port host_port desc is_range range_end
        container_port=$(jq -r ".rules[$i].container_port" "$SOCAT_RULES")
        host_port=$(jq -r ".rules[$i].host_port" "$SOCAT_RULES")
        desc=$(jq -r ".rules[$i].description // \"port-$container_port\"" "$SOCAT_RULES")
        is_range=$(jq -r ".rules[$i].is_range // false" "$SOCAT_RULES")
        range_end=$(jq -r ".rules[$i].range_end // 0" "$SOCAT_RULES")

        if [ "$is_range" = "true" ] && [ "$range_end" -gt "$container_port" ]; then
            for port in $(seq "$container_port" "$range_end"); do
                run_socat "$port" "${desc}-${port}" cooper-proxy "$port"
            done
        else
            run_socat "$container_port" "$desc"
        fi
    done

    sleep 0.3
    echo "Port forwarding active (from $SOCAT_RULES)"
}

reload_socat() {
    echo "[socat] Reloading port forwarding rules..."
    local old=("${SOCAT_SUPERVISORS[@]}")
    SOCAT_SUPERVISORS=()

    # Send TERM to all old supervisors (each kills its socat child via trap).
    for pid in "${old[@]}"; do
        kill "$pid" 2>/dev/null || true
    done
    # Wait for all old supervisors to finish (ensures ports are released).
    for pid in "${old[@]}"; do
        wait "$pid" 2>/dev/null || true
    done

    # Start fresh supervisors from config.
    start_socat_from_config
    echo "[socat] Reload complete."
}

# Handle SIGHUP for live reload
trap 'reload_socat' HUP

echo "Starting port forwarding..."
start_socat_from_config

{{if .ClipboardEnabled}}
# ============================================================================
# CLIPBOARD BRIDGE: Shim Setup
# ============================================================================
# When clipboard mode is "shim" or "auto", install clipboard shim scripts from
# /etc/cooper/shims/ into the user's PATH. Shims intercept xclip/xsel/wl-paste
# calls and serve staged images from the Cooper clipboard bridge.
CLIP_MODE="${COOPER_CLIPBOARD_MODE:-auto}"
if [ "$CLIP_MODE" = "shim" ] || [ "$CLIP_MODE" = "auto" ]; then
  SHIM_DIR="/home/user/.local/bin"
  mkdir -p "$SHIM_DIR"
  if [ -f /etc/cooper/shims/xclip ]; then
    cp /etc/cooper/shims/xclip "$SHIM_DIR/xclip"
    chmod +x "$SHIM_DIR/xclip"
  fi
  if [ -f /etc/cooper/shims/xsel ]; then
    cp /etc/cooper/shims/xsel "$SHIM_DIR/xsel"
    chmod +x "$SHIM_DIR/xsel"
  fi
  if [ -f /etc/cooper/shims/wl-paste ]; then
    cp /etc/cooper/shims/wl-paste "$SHIM_DIR/wl-paste"
    chmod +x "$SHIM_DIR/wl-paste"
  fi
fi

# ============================================================================
# CLIPBOARD BRIDGE: X11/Native Setup
# ============================================================================
# When clipboard mode is "x11" or "auto", start an Xvfb display with xauth
# and launch the X11 clipboard bridge daemon (if available).
if [ "$CLIP_MODE" = "x11" ] || [ "$CLIP_MODE" = "auto" ]; then
  # Use a user-writable location for xauth. /etc/cooper/ is root-owned and
  # read-only from Docker volume mounts, so we write to the user's home dir.
  XAUTH_FILE="/home/user/.cooper-clipboard.xauth"
  DISPLAY_NUM=99
  DISPLAY_ADDR="127.0.0.1:${DISPLAY_NUM}"

  # Generate X authority cookie. We add entries for both the local display form
  # (:99) and the hostname form so Xvfb and native X11 clients can authenticate.
  COOKIE="$(mcookie)"
  xauth -f "$XAUTH_FILE" add ":${DISPLAY_NUM}" . "$COOKIE" 2>/dev/null || true
  chmod 0600 "$XAUTH_FILE" 2>/dev/null || true

  # Save the raw cookie hex for cooper-x11-bridge (it connects via TCP and
  # uses xgb's NewConnNetWithCookieHex to bypass xauth file parsing issues
  # with TCP display name matching).
  COOKIE_HEX_FILE="/home/user/.cooper-clipboard-cookie"
  echo -n "$COOKIE" > "$COOKIE_HEX_FILE"
  chmod 0600 "$COOKIE_HEX_FILE" 2>/dev/null || true

  # Start Xvfb on TCP loopback only
  Xvfb ":${DISPLAY_NUM}" -screen 0 1024x768x24 -auth "$XAUTH_FILE" -listen tcp -nolisten unix >/tmp/xvfb-clipboard.log 2>&1 &

  export DISPLAY="$DISPLAY_ADDR"
  export XAUTHORITY="$XAUTH_FILE"

  # Persist DISPLAY and XAUTHORITY for docker exec sessions (export only
  # affects children of the entrypoint, not new docker exec processes).
  # Write before the interactive guard in .bashrc so non-interactive exec
  # sessions also get them.
  sed -i "1i export DISPLAY=${DISPLAY_ADDR}\nexport XAUTHORITY=${XAUTH_FILE}" /home/user/.bashrc 2>/dev/null || true
  # Also write to .profile for login shells.
  sed -i "1i export DISPLAY=${DISPLAY_ADDR}\nexport XAUTHORITY=${XAUTH_FILE}" /home/user/.profile 2>/dev/null || true

  # Wait for Xvfb to be ready (TCP port 6000+display_num).
  XVFB_PORT=$((6000 + DISPLAY_NUM))
  for _i in $(seq 1 30); do
    if timeout 1 bash -c "echo > /dev/tcp/127.0.0.1/${XVFB_PORT}" 2>/dev/null; then
      break
    fi
    sleep 0.1
  done

  # Start X11 clipboard bridge with auto-restart supervisor.
  # The bridge must stay running as the CLIPBOARD selection owner.
  if command -v cooper-x11-bridge >/dev/null 2>&1; then
    (
      while true; do
        cooper-x11-bridge \
          --display "$DISPLAY_ADDR" \
          --cookie-file "$COOKIE_HEX_FILE" \
          --bridge-url "${COOPER_CLIPBOARD_BRIDGE_URL}" \
          --token-file "${COOPER_CLIPBOARD_TOKEN_FILE}" >>/tmp/x11-bridge.log 2>&1
        # If bridge exits, wait briefly and restart (crash recovery).
        sleep 1
      done
    ) &
  fi
fi
{{end}}
